# Copy to .env and fill in. All values are optional; absent keys degrade
# gracefully (missing data is marked, never fabricated).

# Financial Modeling Prep API key (fundamentals, profiles, ratios).
FMP_API_KEY=

# Alpha Vantage API key (alternative fundamentals / time series).
ALPHAVANTAGE_API_KEY=

# Directory for on-disk caches (prices, fundamentals, HTTP responses).
CONVEXITY_DATA_DIR=./.convexity_data

# Required by the SEC for EDGAR access: an identifiable User-Agent with contact.
SEC_USER_AGENT=Convexity research tool (your-name your-email@example.com)
